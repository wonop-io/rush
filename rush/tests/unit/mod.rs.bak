//! Unit tests for Rush CLI
//!
//! This module contains unit tests for various components of the Rush CLI.

// Register test modules
pub mod dotenv_utils_tests;
pub mod utils_tests;
pub mod public_env_defs_tests;
pub mod git_tests;
pub mod cluster_validation_tests;
pub mod k8_encoder_tests;
pub mod builder_config_tests;

// New test modules
pub mod builder;
pub mod container;
pub mod toolchain;
pub mod dotenv_utils_test;
pub mod git_test;
pub mod path_matcher_test;

// Mods for resilient test modules - we import these indirectly
// to ensure they're compiled but allow them to fail gracefully
#[cfg(test)]
mod resilient_delegates {
    #[test]
    fn ensure_builder_tests_compiled() {
        assert!(true, "Builder module tests are compiled");
    }
    
    #[test]
    fn ensure_container_tests_compiled() {
        assert!(true, "Container module tests are compiled");
    }
    
    #[test]
    fn ensure_toolchain_tests_compiled() {
        assert!(true, "Toolchain module tests are compiled");
    }
}