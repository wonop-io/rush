use std::collections::HashMap;
use std::sync::Arc;
use tempfile::TempDir;
use std::fs::{self, File};
use std::io::Write;
use rush_cli::builder::{ComponentBuildSpec, Config, BuildType, Variables};
use rush_cli::path_matcher::PathMatcher;

#[test]
fn test_component_build_spec_docker_local_name() {
    let spec = create_basic_component_spec();
    
    // Test the docker_local_name method
    assert_eq!(spec.docker_local_name(), "test-product-test-component");
}

#[test]
fn test_component_build_spec_set_services() {
    use rush_cli::container::ServicesSpec;
    
    let mut spec = create_basic_component_spec();
    let services = Arc::new(ServicesSpec::default());
    
    spec.set_services(services.clone());
    
    // Verify services were set
    assert!(spec.services.is_some());
    assert_eq!(
        Arc::as_ptr(&services), 
        Arc::as_ptr(&spec.services.unwrap())
    );
}

#[test]
fn test_component_build_spec_set_domains() {
    let mut spec = create_basic_component_spec();
    let mut domains = HashMap::new();
    domains.insert("api".to_string(), "api.example.com".to_string());
    domains.insert("web".to_string(), "web.example.com".to_string());
    let domains_arc = Arc::new(domains);
    
    spec.set_domains(domains_arc.clone());
    
    // Verify domains were set
    assert!(spec.domains.is_some());
    assert_eq!(
        Arc::as_ptr(&domains_arc), 
        Arc::as_ptr(&spec.domains.unwrap())
    );
}

#[test]
fn test_component_build_spec_set_tagged_image_name() {
    let mut spec = create_basic_component_spec();
    let tagged_image_name = "registry.example.com/test-image:latest";
    
    spec.set_tagged_image_name(tagged_image_name.to_string());
    
    // Verify the tagged image name was set
    assert_eq!(spec.tagged_image_name, Some(tagged_image_name.to_string()));
}

#[test]
fn test_component_build_spec_config() {
    let spec = create_basic_component_spec();
    let config = spec.config();
    
    // Verify the config reference is correct
    assert_eq!(
        Arc::as_ptr(&spec.config), 
        Arc::as_ptr(&config)
    );
}

#[test]
fn test_component_build_spec_build_script() {
    let spec = create_basic_component_spec();
    let ctx = spec.generate_build_context(None, HashMap::new());
    let build_script = spec.build_script(&ctx);
    
    // Verify a BuildScript instance was created
    assert!(build_script.contains("#!/bin/bash") || build_script.is_empty());
}

#[test]
fn test_component_build_spec_build_artefacts() {
    let temp_dir = TempDir::new().expect("Failed to create temporary directory");
    let mut spec = create_basic_component_spec();
    
    // Add artefacts
    let mut artefacts = HashMap::new();
    
    let template_path = temp_dir.path().join("template.txt");
    let template_content = "Hello {{ product_name }}";
    let mut file = File::create(&template_path).expect("Failed to create template file");
    file.write_all(template_content.as_bytes()).expect("Failed to write to template file");
    
    let output_path = temp_dir.path().join("output.txt");
    
    artefacts.insert(
        template_path.to_string_lossy().to_string(),
        output_path.to_string_lossy().to_string()
    );
    
    spec.artefacts = Some(artefacts);
    spec.artefact_output_dir = temp_dir.path().to_string_lossy().to_string();
    
    // Get the artefacts - we only verify that we get back a collection
    let built_artefacts = spec.build_artefacts();
    
    // Only verify the length since we can't reliably access the internal structure
    assert_eq!(built_artefacts.len(), 1);
}

#[test]
fn test_component_build_spec_generate_build_context() {
    let spec = create_basic_component_spec();
    let context = spec.generate_build_context(None, HashMap::new());
    
    // Verify the build context has the expected values
    assert_eq!(context.product_name, "test-product");
    assert_eq!(context.component, "test-component");
    assert_eq!(context.environment, "dev");
    assert_eq!(context.domain, "test-domain.com");
}

// Helper function to create a basic ComponentBuildSpec
fn create_basic_component_spec() -> ComponentBuildSpec {
    let config = Config {
        product_name: "test-product".to_string(),
        product_uri: "test-uri".to_string(),
        product_dirname: "test-dirname".to_string(),
        product_path: "/test/path".to_string(),
        network_name: "net-test".to_string(),
        environment: "dev".to_string(),
        domain_template: "{{product_uri}}.example.com".to_string(),
        kube_context: "test-context".to_string(),
        infrastructure_repository: "git://repo.git".to_string(),
        docker_registry: "registry.example.com".to_string(),
        root_path: "/root".to_string(),
        vault_name: "test-vault".to_string(),
        k8s_encoder: "noop".to_string(),
        k8s_validator: "kubeconform".to_string(),
        k8s_version: "1.25.0".to_string(),
        one_password_account: Some("test-account".to_string()),
        json_vault_dir: Some("/vault/dir".to_string()),
        start_port: 9000,
    };

    // Create a temporary variables file for testing
    let temp_dirs = TempDir::new().expect("Failed to create temporary directory");
    let temp_vars_file = temp_dirs.path().join("variables.yml");
    let vars_content = r#"
dev:
  TEST_VAR: "test_value"
staging: {}
prod: {}
local: {}
"#;
    fs::write(&temp_vars_file, vars_content).expect("Failed to write test variables file");
    
    // Use Variables::new which will create the appropriate structure
    let variables = rush_cli::builder::Variables::new(
        temp_vars_file.to_str().unwrap(),
        "dev",
    );

    ComponentBuildSpec {
        build_type: BuildType::RustBinary {
            location: "/path/to/rust".to_string(),
            dockerfile_path: "/path/to/Dockerfile".to_string(),
            context_dir: None,
            features: None,
            precompile_commands: None,
        },
        product_name: "test-product".to_string(),
        component_name: "test-component".to_string(),
        color: "blue".to_string(),
        depends_on: vec![],
        build: None,
        mount_point: None,
        subdomain: None,
        artefacts: None,
        artefact_output_dir: "/tmp".to_string(),
        docker_extra_run_args: vec![],
        env: None,
        volumes: None,
        port: Some(8080),
        target_port: Some(8080),
        k8s: None,
        priority: 10,
        watch: Some(Arc::new(PathMatcher::new(std::path::Path::new("/"), vec!["**/*.rs".to_string()]))),
        config: Arc::new(config),
        variables,
        services: None,
        domains: None,
        tagged_image_name: None,
        dotenv: HashMap::new(),
        dotenv_secrets: HashMap::new(),
        domain: "test-domain.com".to_string(),
    }
}